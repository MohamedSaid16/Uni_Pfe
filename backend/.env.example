# ══════════════════════════════════════════════════════════════
# 📋 COPY this file → .env   then fill in YOUR values
#    cp .env.example .env     (Linux/Mac)
#    copy .env.example .env   (Windows CMD)
# ══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────
# Choose ONE of the two options below and uncomment it:

# Option A — PostgreSQL (recommended)
# Download: https://www.postgresql.org/download/
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/university_pfe?schema=public"

# Option B — MySQL via XAMPP
# Start XAMPP → Apache + MySQL, then create DB "university_pfe" in phpMyAdmin
# DATABASE_URL="mysql://root:@localhost:3306/university_pfe"

# ── JWT Secrets ───────────────────────────────────────────
JWT_ACCESS_SECRET=pfe-access-secret-dev-2026
JWT_REFRESH_SECRET=pfe-refresh-secret-dev-2026
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Client URL (for CORS) ────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── AI Chatbot (Groq) ─────────────────────────────────────
# Add your Groq API key to enable external AI responses.
# Without this key, the chatbot uses internal fallback responses.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024
